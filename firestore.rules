rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Doctors collection - read-only for authenticated users
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == resource.data.ownerUid || 
         request.auth.token.admin == true);
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.ownerUid;
    }
    
    // Users collection - users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Saved doctors - users can only access their own saved doctors
    match /savedDoctors/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rate limiting for writes
    match /{document=**} {
      allow write: if request.auth != null && 
        request.time > resource.data.lastWrite + duration.value(1, 's');
    }
    
    // Data validation rules
    match /doctors/{doctorId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'specialty', 'city', 'state']) &&
        request.resource.data.name is string &&
        request.resource.data.specialty is string &&
        request.resource.data.city is string &&
        request.resource.data.state is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 100;
    }
  }
}
